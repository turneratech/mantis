# =============================================================================
# Mantis — root .gitignore
# Covers: Express server, React client, portal, hybrid-storage
# =============================================================================

# --- Dependencies ---
node_modules/
**/node_modules/
.pnp
.pnp.js

# --- Build & bundler output ---
client/build/
build/
dist/
out/
.next/
.turbo/
.parcel-cache/
**/.cache/
.eslintcache

# --- Environment & secrets (keep *.env.example tracked) ---
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.p12
*.pfx
license.key
**/license-keys.json
**/mantis-env-snippet.txt

# --- Portal (license API) — runtime / generated ---
portal/data/
portal/.env

# --- Mantis server — runtime / local data ---
uploads/
server/data/deployment.local.json
server/data/*.csv
server/data/bugs_*.csv
server/data/*.local.json

# --- Generated minified bundles (edit non-minified sources only) ---
*.min.js
*.min.css
*.min.map

# --- Logs & diagnostics ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Test & coverage ---
coverage/
.nyc_output/
.coverage/
*.lcov

# --- IDE & editors ---
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
*.code-workspace

# --- Cursor / local AI tooling (not project rules) ---
.cursor/
.claude/
.agent-tools/

# --- OS junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
ehthumbs.db

# --- Process managers (local overrides only; commit example configs) ---
ecosystem.config.local.js
pm2.local.json

# --- Runtime pid files ---
pids/
*.pid
*.seed

# --- Legacy / duplicate static paths ---
client/public/mantis/

# --- Archived assets ---
imgs/old/

# --- Ad-hoc dumps & scratch ---
structure.txt
*.tmp
*.bak
*~
tmp/
temp/

# --- Optional cloud / deploy CLI ---
.vercel/
.netlify/
.serverless/

# --- Database dumps (keep schema SQL in server/database/ and portal/database/) ---
*.sql.gz
*.dump
backup/
