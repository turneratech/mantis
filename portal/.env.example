PORTAL_PORT=4000
PORTAL_JWT_SECRET=change-me-to-a-long-random-string
MANTIS_INSTALL_URL=http://localhost:3000/mantis/setup

# Supabase licensing registry (recommended for production)
# Create a dedicated Supabase project, run portal/database/portal.supabase.sql in SQL Editor,
# then paste the Postgres connection string (Settings → Database → Connection string → URI)
PORTAL_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Alias (optional)
# SUPABASE_DB_URL=

# When PORTAL_DATABASE_URL is unset, accounts/licenses fall back to portal/data/store.json (local dev only)

NODE_ENV=development
