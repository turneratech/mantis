# Mantis Self-Hosted — see docs/DEPLOYMENT.md
PORT=5000
NODE_ENV=development
JWT_SECRET=change-me-in-production
# Dev only: pre-seed admin/admin123 and sample projects in CSV mode
MANTIS_DEV_DEFAULTS=true
# TurnerTech portal (local product page + license issuance)
PORTAL_URL=http://localhost:4000
REACT_APP_PORTAL_URL=http://localhost:4000
# After first `npm run portal`, copy LICENSE_PUBLIC_KEY from portal/data/mantis-env-snippet.txt
LICENSE_PUBLIC_KEY=
DATABASE_PROVIDER=auto
DB_HOST=localhost
DB_PORT=3306
DB_USER=mantis
DB_PASSWORD=
DB_NAME=mantis
DEFAULT_STORAGE=local
WEBHOOKS_ENABLED=true
